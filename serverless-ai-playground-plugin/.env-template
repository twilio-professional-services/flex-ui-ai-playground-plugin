# Twilio Account Configuration
# Your Twilio Account SID (starts with AC)
ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio Auth Token
AUTH_TOKEN=your_auth_token_here

# TaskRouter Configuration
# Workflow SID for routing incoming calls (starts with WW)
WORKFLOW_SID=WWxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Real-Time Transcription Configuration
# Domain resolution priority for transcription webhook URL:
#   1. TRANSCRIPTION_DOMAIN_OVERRIDE (if set, always used - useful for ngrok/tunnels)
#   2. context.DOMAIN_NAME (auto-populated when deployed to Twilio, empty when running locally)
#   3. TRANSCRIPTION_DOMAIN_WHEN_RUN_LOCAL (fallback for local development)
TRANSCRIPTION_DOMAIN_OVERRIDE=
TRANSCRIPTION_DOMAIN_WHEN_RUN_LOCAL=your-service-name-1234-dev.twil.io

# Enable/disable real-time transcription (true/false, case-insensitive)
REALTIME_TRANSCRIPTION=true

# Enable/disable partial transcription results (true/false, case-insensitive)
# Partial results provide real-time interim transcription before final results
REALTIME_TRANSCRIPTION_PARTIAL_RESULTS=true

# Twilio Sync Service Configuration
# Sync Service SID (starts with IS) - defaults to 'default' if not specified
# For Flex accounts, use 'default' which is the built-in Flex Sync service
# For standalone accounts, create a Sync service in the Twilio Console and use its SID
SYNC_SERVICE_SID=ISxxx

# Memora (Customer Memory) Configuration
# Memory Store ID (starts with mem_store_)
MEMORA_STORE_ID=mem_store_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
