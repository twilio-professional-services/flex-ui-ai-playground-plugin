# Flex Plugin Environment Variables Template
# Copy this file to .env and fill in your values
# Variables must start with TWILIO_, FLEX_, or REACT_ to be accessible in the plugin

# Example variables:
# FLEX_APP_TWILIO_SERVERLESS_DOMAIN=https://your-serverless-domain.twil.io
# FLEX_APP_WORKSPACE_SID=WSxxx
# FLEX_APP_WORKFLOW_SID=WWxxx
# TWILIO_WORKFLOW_SID=WWxxx
